# Supabase connection — copy to .env and fill in from your Supabase project
# (Project Settings → API). The anon key is safe for client-side use.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Data source: "supabase" to use the live DB, "local" to use seed data in
# localStorage (no credentials needed). Defaults to "local" when unset.
VITE_DATA_SOURCE=local

# Service role key — used ONLY by Node scripts in scripts/ (set-admin.mjs, test-rls.mjs).
# NEVER import this under src/ and never expose it to the client bundle.
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test account passwords for scripts/test-rls.mjs
# TEST_READER_PW=
# TEST_WRITER_PW=
